[Unit]
Description=soup-rendezvous coordinator daemon
Documentation=https://github.com/8144225309/soup-rendezvous
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=600
StartLimitBurst=5

[Service]
Type=simple
User=root
Group=root

ExecStart=/usr/local/bin/soup-rendezvous --lightning-dir=/var/lib/cln-signet daemon

Environment=SOUP_KEY_FILE=/var/lib/soup-rendezvous/coordinator.nsec
Environment=SOUP_RELAYS=wss://nos.lol,wss://relay.damus.io
Environment=RUST_LOG=soup_rendezvous=info,nostr_relay_pool=warn

Restart=on-failure
RestartSec=10

# Journald log identifier
SyslogIdentifier=soup-rendezvous

# Hardening — block every syscall / fs path we don't actually need.
# Daemon needs: read nsec, spawn lightning-cli, talk to CLN rpc socket,
# make outbound TCP to relays. Everything else denied.
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectKernelLogs=yes
ProtectControlGroups=yes
ProtectClock=yes
ProtectHostname=yes
ProtectProc=invisible
RestrictNamespaces=yes
RestrictRealtime=yes
RestrictSUIDSGID=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallErrorNumber=EPERM

# Read-only access to the key file; read-write only to the CLN socket
# directory (for subprocess calls that may need to write control files)
ReadWritePaths=/var/lib/soup-rendezvous /var/lib/cln-signet

# Resource limits
LimitNOFILE=4096
TasksMax=64

[Install]
WantedBy=multi-user.target
